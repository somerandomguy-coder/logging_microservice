# MongoDB Atlas Configuration (M0 Free Tier)
# Replace with your actual cluster credentials and cluster URI
MONGO_DETAILS=mongodb+srv://admin:fWVgwMHX0c0JBnjn@cluster0.u0spm1q.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=log_db
MONGO_COLLECTION_NAME=app_logs
LOG_RETENTION_DAYS=30

# Upstash Redis Configuration (Free Tier)
# Upstash provides connection URIs starting with 'rediss://' (secured Redis)
REDIS_URL=rediss://default:<password>@<endpoint-name>.upstash.io:<port>
REDIS_QUEUE_NAME=log_ingestion_queue
BATCH_SIZE=100
BATCH_INTERVAL=1.0

# API Security (Optional)
# Comma-separated API keys. Client log shippers must pass a valid key in the 'X-API-Key' header.
# Leave blank to operate in open mode (no API key validation required).
API_KEYS=yoursecretkey1,yoursecretkey2
